# Copy to .env and fill in real values. Validated at boot by src/config/env.ts.

# --- Database (required) ---
# Neon pooler URL. Use the connection string from Neon dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require"

# --- NextAuth (required) ---
# Generate: openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_WITH_AT_LEAST_32_RANDOM_CHARS"
NEXTAUTH_SECRET="${AUTH_SECRET}"
# Public URL of the app — set to your Vercel domain in production.
NEXTAUTH_URL="http://localhost:3000"
# Tells NextAuth to trust the X-Forwarded-Host header (needed on Vercel).
AUTH_TRUST_HOST="true"

# --- Optional toggles ---
# Set to "true" to allow `npm run db:seed` against a NODE_ENV=production database.
# ALLOW_PROD_SEED="true"
# Set to "true" to render the demo-credentials card on the login page (dev/staging only).
# NEXT_PUBLIC_DEMO="true"

# --- Email (optional) ---
# When both RESEND_API_KEY and EMAIL_FROM are set, approval-request
# emails fire on voucher/bill submission. Without them the email
# service is a no-op (logs the intended send at info level).
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"
# EMAIL_FROM="noreply@yourdomain.example"
# Public URL of the app — used to build deep-links into emails.
# Falls back to NEXTAUTH_URL when unset.
# APP_URL="https://accubook.example.com"
