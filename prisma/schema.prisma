// ============================================
// INVOICES & BILLS
// ============================================

model Invoice {
  id               String    @id @default(cuid())
  organizationId   String
  partyId          String
  salesOrderId     String?
  currencyId       String?
  invoiceNumber    String
  date             DateTime
  dueDate          DateTime
  type             String    @default("INVOICE") // INVOICE, CREDIT_NOTE, DEBIT_NOTE, PROFORMA
  status           String    @default("DRAFT") // DRAFT, SENT, PARTIAL, PAID, OVERDUE, CANCELLED
  billingAddress   String?
  shippingAddress  String?
  subtotal         Decimal   @db.Decimal(18, 4)
  discountAmount   Decimal   @default(0) @db.Decimal(18, 4)
  taxAmount        Decimal   @default(0) @db.Decimal(18, 4)
  roundOff         Decimal   @default(0) @db.Decimal(18, 4)
  totalAmount      Decimal   @db.Decimal(18, 4)
  amountPaid       Decimal   @default(0) @db.Decimal(18, 4)
  amountDue        Decimal   @db.Decimal(18, 4)
  exchangeRate     Decimal   @default(1) @db.Decimal(18, 8)
  notes            String?
  terms            String?
  irnNumber        String?   // India e-invoice IRN
  qrCode           String?   // QR code for e-invoice
  eInvoiceStatus   String?   // PENDING, GENERATED, CANCELLED
  // India GST: place of supply (2-letter state code) drives intra/inter
  // determination at invoice creation time. Locked here so the breakdown
  // doesn't shift if party.billingState is later edited.
  placeOfSupply    String?
  supplyType       String?   // INTRASTATE | INTERSTATE | EXPORT
  reverseCharge    Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party               Party             @relation(fields: [partyId], references: [id])
  salesOrder          SalesOrder?       @relation(fields: [salesOrderId], references: [id])
  currency            Currency?         @relation(fields: [currencyId], references: [id])
  items               InvoiceItem[]
  taxes               InvoiceTax[]
  payments            InvoicePayment[]
  receipts            Receipt[]
  recurringSourceFor  RecurringInvoice? @relation("RecurringLastInvoice")

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId, date])
  @@index([organizationId, status])
  @@map("invoices")
}

/**
 * Recurring invoice template. The system runs a tick (manual via the
 * /run endpoint, or by an external cron) and for every active recurring
 * row whose nextRunDate is <= today, creates a fresh Invoice from the
 * stored items + party + due-days, then advances nextRunDate by the
 * frequency.
 *
 * `items` is JSON: an array of { itemId, quantity, unitPrice,
 * discountPercent, taxId, description } matching the Invoice POST
 * shape — so the runner just forwards it through. Schema-validated
 * by zod when the recurring template is created.
 */
model RecurringInvoice {
  id              String   @id @default(cuid())
  organizationId  String
  partyId         String
  /** "DAILY" | "WEEKLY" | "MONTHLY" | "QUARTERLY" | "YEARLY" */
  frequency       String
  /** First-run date — drives nextRunDate at creation. */
  startDate       DateTime
  /** Optional cap. If set, runs stop after endDate even if isActive. */
  endDate         DateTime?
  /** Computed by the runner; advanced after each successful invoice creation. */
  nextRunDate     DateTime
  /** Days from invoice date → due date on each spawned invoice. */
  dueDays         Int      @default(15)
  /** JSON: invoice item template (see model docstring). */
  items           Json
  /** JSON: optional notes / terms / supplyType / billingAddress / shippingAddress. */
  meta            Json?
  isActive        Boolean  @default(true)
  /** Last invoice spawned by this template; soft-link for the UI / audit. */
  lastInvoiceId   String?  @unique
  /** Counter — convenience so the UI can show "12 invoices spawned". */
  runCount        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party        Party        @relation(fields: [partyId], references: [id])
  lastInvoice  Invoice?     @relation("RecurringLastInvoice", fields: [lastInvoiceId], references: [id])

  @@index([organizationId, isActive, nextRunDate])
  @@map("recurring_invoices")
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  itemId          String?
  description     String
  hsnCode         String?
  quantity        Decimal  @db.Decimal(18, 4)
  unitPrice       Decimal  @db.Decimal(18, 4)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(18, 4)
  taxableAmount   Decimal  @db.Decimal(18, 4)
  taxId           String?
  taxAmount       Decimal  @default(0) @db.Decimal(18, 4)
  // GST breakdown — one combined rate splits into either CGST+SGST
  // (intrastate) or IGST (interstate). CESS is rare; modeled separately.
  cgstRate        Decimal? @db.Decimal(5, 2)
  cgstAmount      Decimal? @db.Decimal(18, 4)
  sgstRate        Decimal? @db.Decimal(5, 2)
  sgstAmount      Decimal? @db.Decimal(18, 4)
  igstRate        Decimal? @db.Decimal(5, 2)
  igstAmount      Decimal? @db.Decimal(18, 4)
  cessRate        Decimal? @db.Decimal(5, 2)
  cessAmount      Decimal? @db.Decimal(18, 4)
  totalAmount     Decimal  @db.Decimal(18, 4)
  sequence        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoice Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    Item?      @relation(fields: [itemId], references: [id])
  tax     TaxConfig? @relation(fields: [taxId], references: [id])

  @@map("invoice_items")
}

model InvoiceTax {
  id           String   @id @default(cuid())
  invoiceId    String
  taxId        String
  taxableAmount Decimal @db.Decimal(18, 4)
  taxAmount    Decimal  @db.Decimal(18, 4)
  createdAt    DateTime @default(now())

  invoice Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tax     TaxConfig @relation(fields: [taxId], references: [id])

  @@map("invoice_taxes")
}

model Bill {
  id               String    @id @default(cuid())
  organizationId   String
  partyId          String
  purchaseOrderId  String?
  currencyId       String?
  billNumber       String
  vendorBillNo     String?
  date             DateTime
  dueDate          DateTime
  type             String    @default("BILL") // BILL, DEBIT_NOTE, CREDIT_NOTE
  status           String    @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, PARTIAL, PAID, OVERDUE, CANCELLED
  subtotal         Decimal   @db.Decimal(18, 4)
  discountAmount   Decimal   @default(0) @db.Decimal(18, 4)
  taxAmount        Decimal   @default(0) @db.Decimal(18, 4)
  tdsAmount        Decimal   @default(0) @db.Decimal(18, 4)
  roundOff         Decimal   @default(0) @db.Decimal(18, 4)
  totalAmount      Decimal   @db.Decimal(18, 4)
  amountPaid       Decimal   @default(0) @db.Decimal(18, 4)
  amountDue        Decimal   @db.Decimal(18, 4)
  exchangeRate     Decimal   @default(1) @db.Decimal(18, 8)
  notes            String?
  attachments      Json?
  // India GST: place of supply on the purchase side. Place of supply is
  // the receiver's state for goods; for services it can differ. Locked at
  // creation so the breakdown doesn't shift under us.
  placeOfSupply    String?
  supplyType       String?   // INTRASTATE | INTERSTATE | IMPORT
  reverseCharge    Boolean   @default(false)
  // Set once the bill is APPROVED and posted to GL via postBillToGl.
  // The Voucher carries the actual ledger entries; this is the FK back.
  voucherId        String?   @unique
  // TDS at bill time (accrual basis). When set, the posting voucher
  // includes Cr TDS Payable and a TdsDeduction row is persisted for
  // Form 16A reporting.
  tdsSection       String?
  tdsRationale     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party         Party          @relation(fields: [partyId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  currency      Currency?      @relation(fields: [currencyId], references: [id])
  voucher       Voucher?       @relation("BillVoucher", fields: [voucherId], references: [id])
  tdsDeductions TdsDeduction[]
  items         BillItem[]
  taxes         BillTax[]
  payments      Payment[]

  @@unique([organizationId, billNumber])
  @@index([organizationId, date])
  @@map("bills")
}

model BillItem {
  id              String   @id @default(cuid())
  billId          String
  itemId          String?
  description     String
  hsnCode         String?
  quantity        Decimal  @db.Decimal(18, 4)
  unitPrice       Decimal  @db.Decimal(18, 4)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(18, 4)
  taxableAmount   Decimal  @db.Decimal(18, 4)
  taxId           String?
  taxAmount       Decimal  @default(0) @db.Decimal(18, 4)
  // GST breakdown — same shape as InvoiceItem (purchases need ITC tracking).
  cgstRate        Decimal? @db.Decimal(5, 2)
  cgstAmount      Decimal? @db.Decimal(18, 4)
  sgstRate        Decimal? @db.Decimal(5, 2)
  sgstAmount      Decimal? @db.Decimal(18, 4)
  igstRate        Decimal? @db.Decimal(5, 2)
  igstAmount      Decimal? @db.Decimal(18, 4)
  cessRate        Decimal? @db.Decimal(5, 2)
  cessAmount      Decimal? @db.Decimal(18, 4)
  totalAmount     Decimal  @db.Decimal(18, 4)
  sequence        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bill Bill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  item Item?      @relation(fields: [itemId], references: [id])
  tax  TaxConfig? @relation(fields: [taxId], references: [id])

  @@map("bill_items")
}

model BillTax {
  id           String   @id @default(cuid())
  billId       String
  taxId        String
  taxableAmount Decimal @db.Decimal(18, 4)
  taxAmount    Decimal  @db.Decimal(18, 4)
  createdAt    DateTime @default(now())

  bill Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  tax  TaxConfig @relation(fields: [taxId], references: [id])

  @@map("bill_taxes")
}

// ============================================
// PAYMENTS & RECEIPTS
// ============================================

model Receipt {
  id             String   @id @default(cuid())
  organizationId String
  partyId        String
  invoiceId      String?
  voucherId      String?
  receiptNumber  String
  date           DateTime
  amount         Decimal  @db.Decimal(18, 4)
  paymentMode    String   // CASH, BANK_TRANSFER, CHEQUE, UPI, CARD
  bankAccountId  String?
  chequeNo       String?
  chequeDate     DateTime?
  transactionRef String?
  notes          String?
  status         String   @default("COMPLETED") // PENDING, COMPLETED, BOUNCED, CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party           Party            @relation(fields: [partyId], references: [id])
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  bankAccount     BankAccount?     @relation(fields: [bankAccountId], references: [id])
  voucher         Voucher?         @relation("ReceiptVoucher", fields: [voucherId], references: [id])
  tcsCollections  TcsCollection[]

  @@unique([organizationId, receiptNumber])
  @@map("receipts")
}

/**
 * Per-receipt TCS collection record. Mirrors TdsDeduction; powers
 * Form 27D quarterly statement, 26AS reconciliation, and the TCS
 * register.
 */
model TcsCollection {
  id             String   @id @default(cuid())
  organizationId String
  receiptId      String
  partyId        String
  voucherId      String
  fiscalYearId   String

  section        String   // "206C_1H" | "206C_1F"
  deducteeType   String
  ratePercent    Decimal  @db.Decimal(5, 2)
  baseAmount     Decimal  @db.Decimal(18, 4)
  taxAmount      Decimal  @db.Decimal(18, 4)
  noPan          Boolean  @default(false)
  rationale      String

  collectedAt    DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  receipt      Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  party        Party        @relation(fields: [partyId], references: [id])
  voucher      Voucher      @relation("TcsVoucher", fields: [voucherId], references: [id])
  fiscalYear   FiscalYear   @relation("TcsFY", fields: [fiscalYearId], references: [id])

  @@index([organizationId, fiscalYearId, section])
  @@index([organizationId, partyId, fiscalYearId])
  @@index([receiptId])
  @@map("tcs_collections")
}

model Payment {
  id             String   @id @default(cuid())
  organizationId String
  partyId        String
  billId         String?
  voucherId      String?
  paymentNumber  String
  date           DateTime
  amount         Decimal  @db.Decimal(18, 4)
  paymentMode    String   // CASH, BANK_TRANSFER, CHEQUE, NEFT, RTGS, UPI
  bankAccountId  String?
  chequeNo       String?
  chequeDate     DateTime?
  transactionRef String?
  notes          String?
  status         String   @default("COMPLETED") // PENDING, COMPLETED, FAILED, CANCELLED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  party          Party           @relation(fields: [partyId], references: [id])
  bill           Bill?           @relation(fields: [billId], references: [id])
  bankAccount    BankAccount?    @relation(fields: [bankAccountId], references: [id])
  voucher        Voucher?        @relation("PaymentVoucher", fields: [voucherId], references: [id])
  tdsDeductions  TdsDeduction[]

  @@unique([organizationId, paymentNumber])
  @@map("payments")
}

/**
 * Per-payment TDS deduction record. Set by payments POST when the
 * caller flags a section. The audit log captures the same data, but
 * this table is queryable: drives Form 16A quarterly statements,
 * 26AS reconciliation, monthly challan generation, and the TDS
 * register report.
 */
model TdsDeduction {
  id             String   @id @default(cuid())
  organizationId String
  /**
   * Source of the deduction. Exactly ONE of paymentId / billId is set:
   *   paymentId → cash-basis (deducted at payment time, the original flow).
   *   billId    → accrual-basis (deducted at bill recording time).
   */
  paymentId      String?
  billId         String?
  partyId        String
  voucherId      String   // the JV that booked the deduction
  fiscalYearId   String

  /** TDS section code (e.g. "194C", "194J", "194Q"). */
  section        String
  /** "INDIVIDUAL_HUF" | "COMPANY_OTHER" — affects rate for some sections. */
  deducteeType   String
  /** Effective rate as percent (1 means 1%, not 0.01). */
  ratePercent    Decimal  @db.Decimal(5, 2)
  /** Base on which TDS was applied (typically the payment/bill amount net of GST). */
  baseAmount     Decimal  @db.Decimal(18, 4)
  /** Actual TDS deducted. */
  taxAmount      Decimal  @db.Decimal(18, 4)
  /** PAN missing → 20% penal rate flag. */
  noPan          Boolean  @default(false)
  /** "DEDUCTED" | "BELOW_SINGLE_THRESHOLD" | "BELOW_ANNUAL_THRESHOLD" | "ZERO_RATE". */
  rationale      String

  deductedAt     DateTime
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payment      Payment?     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  bill         Bill?        @relation(fields: [billId], references: [id], onDelete: Cascade)
  party        Party        @relation(fields: [partyId], references: [id])
  voucher      Voucher      @relation("TdsVoucher", fields: [voucherId], references: [id])
  fiscalYear   FiscalYear   @relation("TdsFY", fields: [fiscalYearId], references: [id])

  @@index([organizationId, fiscalYearId, section])
  @@index([organizationId, partyId, fiscalYearId])
  @@index([paymentId])
  @@index([billId])
  @@map("tds_deductions")
}

model InvoicePayment {
  id        String   @id @default(cuid())
  invoiceId String?
  billId    String?
  voucherId String
  amount    Decimal  @db.Decimal(18, 4)
  date      DateTime
  createdAt DateTime @default(now())

  invoice Invoice? @relation(fields: [invoiceId], references: [id])
  voucher Voucher  @relation(fields: [voucherId], references: [id])

  @@map("invoice_payments")
}

