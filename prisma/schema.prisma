model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String
  action         String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, EXPORT
  entityType     String
  entityId       String?
  oldData        Json?
  newData        Json?
